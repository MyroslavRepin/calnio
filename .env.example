# Copy to .env and fill in. Every key without a default is required —
# Settings() fails fast on startup if one is missing.

# iCloud CalDAV
ICLOUD_EMAIL=
APP_SPECIFIC_PASSWORD=
CALDAV_URL=https://caldav.icloud.com

# Notion
NOTION_TOKEN=
TASKS_DATA_SOURCE=
EVENT_DUE_DATE_FIELD_NAME=Due Date

# Database (psycopg3 driver)
DB_URL=postgresql+psycopg://user:pass@host:5432/calnio

# Scheduler
SYNCING_INTERVAL_MINUTES=15

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/auth/oauth/google/callback

# Secrets (generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
SESSION_SECRET=
JWT_SECRET=

# --- Auth cookie / CORS (optional, have defaults suited to dev cross-origin) ---
# Frontend origin the OAuth callback redirects to and the CORS allow-origin.
FRONTEND_URL=http://localhost:5173
# Refresh-cookie policy. Dev cross-origin (5173 -> 8080) needs none + secure.
# Prod same-origin: set COOKIE_SAMESITE=lax.
COOKIE_SECURE=true
COOKIE_SAMESITE=none
# COOKIE_DOMAIN=
